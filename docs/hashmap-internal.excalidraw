      "strokeWidth": 2
    },
    {
      "id": "aBcDeGC",
      "type": "text",
      "x": 670,
      "y": 430,
      "width": 280,
      "height": 20,
      "fill": "#c92a2a",
      "strokeColor": "#c92a2a",
      "backgroundColor": "transparent",
      "strokeWidth": 0,
      "text": "关键特性",
      "fontSize": 14,
      "fontFamily": "Arial",
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12
    },
    {
      "id": "aBcDeGD",
      "type": "text",
      "x": 670,
      "y": 460,
      "width": 280,
      "height": 130,
      "fill": "#1e1e1e",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "strokeWidth": 0,
      "text": "线程不安全 (无 synchronized)\n允许 null 键和 null 值\n不保证元素顺序\n初始容量: 16 (必须是 2 的幂)\n最大容量: 2^30\nfail-fast 迭代器 (modCount)",
      "fontSize": 12,
      "fontFamily": "Arial",
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10
    }

    {
      "id": "aBcDeFv",
      "type": "text",
      "x": 60,
      "y": 430,
      "width": 330,
      "height": 20,
      "fill": "#5f3dc4",
      "strokeColor": "#5f3dc4",
      "backgroundColor": "transparent",
      "strokeWidth": 0,
      "text": "链表 vs 红黑树 (JDK 1.8+)",
      "fontSize": 14,
      "fontFamily": "Arial",
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12
    },
    {
      "id": "aBcDeFw",
      "type": "text",
      "x": 60,
      "y": 460,
      "width": 330,
      "height": 60,
      "fill": "#1e1e1e",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "strokeWidth": 0,
      "text": "桶内 < 8 元素: 链表 O(n)\n桶内 >= 8 元素 + 数组 >= 64: 红黑树 O(log n)\n红黑树 < 6 元素: 退回链表",
      "fontSize": 12,
      "fontFamily": "Arial",
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10
    },
    {
      "id": "aBcDeFx",
      "type": "text",
      "x": 60,
      "y": 530,
      "width": 330,
      "height": 40,
      "fill": "#1e1e1e",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "strokeWidth": 0,
      "text": "扰动函数: hash = key.hashCode() ^ (h >>> 16)",
      "fontSize": 12,
      "fontFamily": "Arial",
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10
    },
    {
      "id": "aBcDeFy",
      "type": "rectangle",
      "x": 430,

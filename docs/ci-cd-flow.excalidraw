{
  "type": "excalidraw",
  "version": 2,
  "source": "https://excalidraw.com",
  "elements": [
    {
      "id": "title",
      "type": "text",
      "text": "CI/CD Pipeline 运作流程",
      "x": 400,
      "y": 50,
      "fontSize": 32,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle"
    },
    {
      "id": "commit_box",
      "type": "rectangle",
      "x": 80,
      "y": 150,
      "width": 120,
      "height": 60,
      "fillColor": "#1971c2",
      "strokeColor": "#1971c2",
      "strokeWidth": 2,
      "roughness": 0
    },
    {
      "id": "commit_text",
      "type": "text",
      "text": "git push",
      "x": 80,
      "y": 165,
      "width": 120,
      "fontSize": 18,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle"
    },
    {
      "id": "arrow1",
      "type": "arrow",
      "points": [[200, 180], [280, 180]],
      "strokeColor": "#495057",
      "strokeWidth": 2
    },
    {
      "id": "lint_box",
      "type": "rectangle",
      "x": 290,
      "y": 140,
      "width": 140,
      "height": 80,
      "fillColor": "#fab005",
      "strokeColor": "#fab005",
      "strokeWidth": 2,
      "roughness": 0
    },
    {
      "id": "lint_text",

      "x": 290,
      "y": 160,
      "width": 140,
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle"
    },
    {
      "id": "arrow2",
      "type": "arrow",
      "points": [[430, 180], [510, 180]],
      "strokeColor": "#495057",
      "strokeWidth": 2
    },

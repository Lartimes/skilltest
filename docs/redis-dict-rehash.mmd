# Redis Dict Rehash 架构图

## Mermaid 源码

```mermaid
flowchart TB
    subgraph DICT["Redis Dict 结构"]
        A["dict<br/>核心结构"]
        B["ht[0]<br/>主 Hash 表"]
        C["ht[1]<br/>渐进式 Rehash 表"]
        D["rehashidx = -1<br/>Rehash 进度指针"]
        E["iterators<br/>安全迭代器计数"]
        
        A --> B
        A --> C
        A --> D
        A --> E
    end

    subgraph HT["Hash Table 结构"]
        F["ht<br/>size: 桶数量<br/>sizemask: size-1<br/>used: 元素个数"]
        G["dictht<br/>table: 桶数组"]
        
        F --> G
    end

    subgraph REHASH["渐进式 Rehash 流程"]
        H{{"需要扩容?"}}
        I["启用 ht[1]<br/>容量 = ht[0].used × 2"]
        J["rehashidx = 0<br/>开始迁移"]
        K["迁移 ht[rehashidx]<br/>单个桶内所有节点"]
        L["rehashidx++"]
        M{{"ht[0].used == 0?"}}
        N["释放 ht[0]<br/>ht[1] → ht[0]"]
        O["rehashidx = -1<br/>重置状态"]
        
        H -- "Yes" --> I
        I --> J
        J --> K
        K --> L
        L --> M
        M -- "No" --> H2["继续下次访问时<br/>渐进迁移"]
        M -- "Yes" --> N
        N --> O
        H -- "No" --> H2
    end

    subgraph OPERATION["读写操作"]
        P{{"是否正在 Rehash?<br/>rehashidx != -1"}}
        Q["读操作<br/>同时查询 ht[0] 和 ht[1]"]]
        R["写操作<br/>仅写入 ht[1]"]
        S["增删改查<br/>都会触发渐进迁移"]
        
        P -- "Yes" --> Q
        P -- "Yes" --> R
        P -- "No" --> S
        Q --> T["迁移一个桶"]
        R --> T
        T --> U["单步完成"]
    end

    subgraph THRESHOLD["触发条件"]
        V["扩容阈值<br/>used/size >= 1"]
        W["缩容阈值<br/>used/size <= 0.1"]
        X["最大容量<br/>1 << 63"]
    end

    subgraph SERVER["服务调用点"]
        Y["dictAdd<br/>添加键值对"]
        Z["dictReplace<br/>替换键值对"]
        AA["dictDelete<br/>删除键值对"]
        AB["dictFetchValue<br/>查找键"]
        AC["serverCron<br/>后台定时任务"]
        
        Y & Z & AA & AB & AC --> P
    end

    D --> H
    R --> J

    %%Styles
    classDef dictStruct fill:#E3F2FD,stroke:#1565C0,stroke-width:2px
    classDef htStruct fill:#F3E5F5,stroke:#7B1FA2,stroke-width:2px
    classDef rehashFlow fill:#FFF3E0,stroke:#E65100,stroke-width:2px
    classDef operation fill:#E8F5E9,stroke:#2E7D32,stroke-width:2px
    classDef decision fill:#FCE4EC,stroke:#C62828,stroke-width:2px
    classDef trigger fill:#F1F8E9,stroke:#558B2F,stroke-width:2px

    class A,DICT dictStruct
    class F,G,HT htStruct
    class H,I,J,K,L,M,N,O,REHASH rehashFlow
    class P,Q,R,S,T,U,OPERATION operation
    class V,W,X,THRESHOLD trigger
    class Y,Z,AA,AB,AC,SERVER decision
```
